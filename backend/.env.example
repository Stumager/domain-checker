HOST=127.0.0.1
PORT=8080
DEBUG=False
# SECRET_KEY=your-secret-key-here  (auto-generated on each start if not set)
CORS_ORIGINS=
MAX_DOMAINS=200000

FINAL_CHECK_ENABLED=1
FINAL_CHECK_WORKERS=20
RDAP_TIMEOUT=7.0
RDAP_RETRIES=2
DEFAULT_TLDS=es it pl fr de pt nl be se fi no dk tr in ca br mx co
DNS_PREFILTER_STRICT_TLDS=com in co mx

# Per-TLD RDAP concurrency caps (JSON) — lower values reduce 429 rate-limit errors
# RDAP_CONCURRENCY_OVERRIDES={"de": 3, "es": 2, "it": 4, "br": 4, "in": 6}

# Per-TLD RDAP endpoint overrides (JSON) — bypass bootstrap for known endpoints
# RDAP_TLD_OVERRIDES={"de": "https://rdap.denic.de/", "es": "https://rdap.nic.es/rdap/"}

BROWSER_MONITOR_ENABLED=1
BROWSER_MONITOR_TIMEOUT=60
BROWSER_MONITOR_STARTUP_GRACE=30
BROWSER_MONITOR_SHUTDOWN_DELAY=3
AUTO_OPEN_BROWSER=1
